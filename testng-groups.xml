<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="HireGrad Group Runner Suite" verbose="1">

    <listeners>
        <listener class-name="com.tests.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Selected Group Tests">

        <groups>
            <run>
                <include name="smoke"/>
                
                <!-- 
                <exclude name="negative"/>
                -->
            </run>
        </groups>

        <classes>
            <class name="com.tests.login.TS01_AdminLoginTests"/>
            <class name="com.tests.login.TS02_StudentLoginTests"/>
            <class name="com.tests.admin.TS03_AdminDashboardTests"/>
            <class name="com.tests.admin.TS04_AdminJobPostingTests"/>
            <class name="com.tests.admin.TS05_ApplicationManagementTests"/>
            <class name="com.tests.admin.TS06_PlacementReportTests"/>
            <class name="com.tests.admin.TS07_AdminProfileTests"/>
            <class name="com.tests.student.TS08_StudentDashboardTests"/>
            <class name="com.tests.student.TS09_StudentProfileTests"/>
            <class name="com.tests.student.TS10_StudentJobsTests"/>
            <class name="com.tests.shared.TS12_NotificationTests"/>
            <class name="com.tests.shared.TS13_NavigatorBotTests"/>
            <class name="com.tests.shared.TS14_ThemeTests"/>
        </classes>

    </test>

</suite>
